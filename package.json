{
  "name": "workout",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Personal workout planner + AI assistant — Capacitor wrapper for iOS App Store",
  "scripts": {
    "build": "echo 'no-build: index.html is the bundle' && exit 0",
    "ios:add":   "cap add ios",
    "ios:sync":  "cap sync ios",
    "ios:open":  "cap open ios",
    "ios:run":   "cap run ios"
  },
  "dependencies": {
    "@capacitor/core":     "^6.1.2",
    "@capacitor/ios":      "^6.1.2",
    "@capacitor/cli":      "^6.1.2",
    "@capacitor/app":      "^6.0.1",
    "@capacitor/browser":  "^6.0.2",
    "@capacitor/preferences": "^6.0.2",
    "@capacitor/camera":   "^6.0.2",
    "@capacitor/filesystem": "^6.0.1",
    "@capacitor-mlkit/barcode-scanning": "6.2.0",
    "@perfood/capacitor-healthkit": "1.3.2",
    "@revenuecat/purchases-capacitor": "^9.0.0"
  }
}
