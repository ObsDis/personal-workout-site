{
  "appId": "com.obsidiandist.workout",
  "appName": "BarbellMind",
  "webDir": "www",
  "ios": {
    "scheme": "Workout",
    "contentInset": "never",
    "limitsNavigationsToAppBoundDomains": false,
    "preferredContentMode": "mobile",
    "backgroundColor": "#0a0a0a"
  },
  "server": {
    "iosScheme": "workout",
    "cleartext": false
  },
  "plugins": {
    "App": {
      "launchUrl": ""
    },
    "Camera": {
      "androidScaleType": "CENTER_CROP"
    },
    "Keyboard": {
      "resize": "native",
      "style": "dark",
      "resizeOnFullScreen": true
    }
  }
}